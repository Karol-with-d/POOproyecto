{
  "name": "plataforma-ciencias-backend",
  "version": "1.0.0",
  "description": "Backend API para plataforma de aprendizaje de ciencias - UNIVO POO 2026",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "ts-node prisma/seed.ts",
    "postinstall": "prisma generate",
    "db:setup": "ts-node src/scripts/db-setup.ts",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "keywords": [
    "univo",
    "poo",
    "ciencias",
    "educacion"
  ],
  "author": "Equipo POO 2026",
  "license": "MIT",
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^6.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.3.2",
    "morgan": "^1.11.0",
    "mysql2": "^3.22.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.10.4",
    "nodemon": "^3.0.2",
    "prisma": "^6.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
